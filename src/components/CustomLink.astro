---
const { text, icon, url } = Astro.props;
---

<li class="w-full max-w-md text-center">
  <a
    href={url}
    class="flex items-center justify-center gap-2 rounded-full bg-gradient-to-r from-blue-600 to-purple-600 px-6 py-4 text-lg font-semibold text-white shadow-lg transition-all hover:scale-105 hover:from-blue-500 hover:to-purple-500 hover:shadow-xl dark:from-blue-700 dark:to-purple-700 dark:hover:from-blue-600 dark:hover:to-purple-600"
  >
    <slot />
  </a>
</li>
